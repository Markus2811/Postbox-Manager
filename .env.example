# Optional: Canonical URL for Open Graph / metadata (custom production domain).
# Falls leer: auf Vercel wird https://$VERCEL_URL genutzt, lokal http://localhost:3000.
# NEXT_PUBLIC_SITE_URL=https://postbox.example.com

# Supabase – wähle eine Variante:
#
# A) Hosted (dein Projekt): URL + anon/publishable Key aus
#    Dashboard → Settings → API (Beispiel-URL: https://hvzjirhwagfvpmmkqxdk.supabase.co)
#
# B) Lokal: Docker Desktop, dann `npm run supabase:start` und Keys mit `npm run supabase:status`
#
# Vercel: dieselben Keys unter Project → Settings → Environment Variables (Production).
# Anon-Key ist für Browser-Session + RLS gedacht – nicht mit Service Role verwechseln.
NEXT_PUBLIC_SUPABASE_URL=https://hvzjirhwagfvpmmkqxdk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Nur für Admin-Skripte (z. B. npm run admin:delete-docs): Service Role aus dem Supabase-Dashboard.
# SUPABASE_SERVICE_ROLE_KEY=
#
# Alternative ohne Service Role: Konto leeren (npm run admin:delete-docs -- <email>)
# POSTBOX_PURGE_EMAIL=markus.greil@hotmail.de
# POSTBOX_PURGE_PASSWORD=

# Auth: Wenn nach Registrierung keine Mail ankommt oder Login blockiert ist → im Supabase-Dashboard
# „Authentication → Providers → Email“ die Option „Confirm email“ für Tests deaktivieren,
# oder SMTP unter Project Settings → Auth einrichten (siehe Supabase-Doku „Custom SMTP“).

# OpenAI (Pflicht für POST /api/documents/analyze – z. B. gleiche Werte wie in ../.env)
OPENAI_API_KEY=
# Korrekt: gpt-4o-mini (Buchstabe „o“ in 4o). Nicht gpt-40-mini (Ziffer 0).
OPENAI_MODEL=gpt-4o-mini

# Optional: npm run loadtest:four – Upload+Analyse der PDFs 13–16
# POSTBOX_MARKUS_EMAIL=     # bevorzugt (echtes „Markus“-Konto in der App)
# POSTBOX_MARKUS_PASSWORD=
# POSTBOX_LOADTEST_EMAIL=   # Alternative
# POSTBOX_LOADTEST_PASSWORD=
# Ohne Angabe: reports/.markus-loadtest-creds.json oder einmalige Auto-Registrierung (siehe Skript).
